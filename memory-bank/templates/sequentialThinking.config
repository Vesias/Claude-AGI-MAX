{
  "version": "2.0.0",
  "mcpEndpoint": "http://localhost:3000/api/sequential-thinking",
  "maxSteps": 7,
  "storeHistory": true,
  "appendToActiveContext": true,
  "defaultStepTitles": [
    "Problem-Definition und Kontext",
    "Informationssammlung und Analyse",
    "Hypothesenbildung",
    "Alternativen-Bewertung",
    "Lösungs-Design",
    "Implementierungsstrategie",
    "Risiko-Analyse und Mitigation"
  ],
  "thinkingModels": {
    "problem-solving": {
      "steps": [
        "Problem-Definition und Kontext",
        "Informationssammlung und Analyse",
        "Hypothesenbildung",
        "Alternativen-Bewertung",
        "Lösungs-Design",
        "Implementierungsstrategie",
        "Risiko-Analyse und Mitigation"
      ]
    },
    "decision-making": {
      "steps": [
        "Entscheidungs-Kontext",
        "Kriterien-Definition",
        "Optionen-Identifikation",
        "Informationssammlung",
        "Bewertung jeder Option",
        "Vergleich und Priorisierung",
        "Entscheidung und Aktionsplan"
      ]
    },
    "code-design": {
      "steps": [
        "Anforderungs-Analyse",
        "Architektur-Muster-Identifikation",
        "Komponentenmodell-Entwurf",
        "Schnittstellen-Design",
        "Datenmodell-Definition",
        "Algorithmenauswahl und Optimierung",
        "Testablility und Wartbarkeitsbetrachtung"
      ]
    },
    "debug": {
      "steps": [
        "Fehler-Symptome-Dokumentation",
        "Reproduktionsschritte-Identifikation",
        "Daten- und Loganalyse",
        "Hypothesenbildung zur Fehlerursache",
        "Hypothesentestung",
        "Fehlerbeseitigung",
        "Verifikation und Regression"
      ]
    },
    "research": {
      "steps": [
        "Forschungsfrage-Definition",
        "Literatur- und Ressourcenrecherche",
        "Datensammlung und -analyse",
        "Muster- und Trenderkennung",
        "Hypothesenbildung",
        "Schlussfolgerungen und Erkenntnisse",
        "Anwendungsvorschläge"
      ]
    }
  },
  "outputFormats": {
    "markdown": true,
    "json": true,
    "mindmap": true
  },
  "integrations": {
    "knowledgeGraph": {
      "enabled": true,
      "updateGraph": true,
      "conceptType": "thinking"
    },
    "activeContext": {
      "enabled": true,
      "section": "## Structured Thinking",
      "includeTimestamp": true,
      "includeDiagram": true
    }
  }
}