{
  "thinking_modes": {
    "default": {
      "max_thoughts": 5,
      "strategy": "linear",
      "thought_token_limit": 256
    },
    "complex_problem": {
      "max_thoughts": 10,
      "strategy": "tree",
      "thought_token_limit": 512
    },
    "creative": {
      "max_thoughts": 8,
      "strategy": "divergent",
      "thought_token_limit": 384
    },
    "analytical": {
      "max_thoughts": 12,
      "strategy": "depth_first",
      "thought_token_limit": 640
    },
    "comparative": {
      "max_thoughts": 6,
      "strategy": "parallel",
      "thought_token_limit": 320
    }
  },
  "memory_settings": {
    "short_term": {
      "max_thoughts": 20,
      "ttl": "session"
    },
    "long_term": {
      "max_thoughts": 100,
      "ttl": "permanent",
      "storage": "knowledgeGraph"
    },
    "working": {
      "max_thoughts": 10,
      "ttl": "6h",
      "storage": "memory"
    }
  },
  "integration": {
    "mcp_server": "sequentialthinking",
    "mcp_version": "1.0",
    "active": true,
    "persistence": {
      "enabled": true,
      "storage_type": "file",
      "storage_path": "/home/jan/.claude/memory_storage/sequential_thinking"
    }
  },
  "visualization": {
    "enabled": true,
    "format": "mermaid",
    "include_attributes": ["thoughtNumber", "strategy", "next_steps"],
    "style": {
      "node_color": "#d4f1f9",
      "edge_color": "#05728f",
      "highlight_color": "#f9e0f3"
    }
  },
  "techniques": [
    {
      "name": "decomposition",
      "description": "Zerlege komplexe Probleme in kleinere, lösbare Teile",
      "trigger_words": ["komplex", "umfangreich", "schwierig", "mehrschichtig"]
    },
    {
      "name": "socratic_method",
      "description": "Stelle Fragen, um Annahmen zu hinterfragen und tieferes Verständnis zu gewinnen",
      "trigger_words": ["annahme", "glaube", "behauptung", "voraussetzung"]
    },
    {
      "name": "counterfactual",
      "description": "Betrachte alternative Szenarien und ihre Auswirkungen",
      "trigger_words": ["alternativ", "wenn", "könnte", "würde", "hätte"]
    },
    {
      "name": "first_principles",
      "description": "Zerlege Probleme auf grundlegende Wahrheiten und baue von dort auf",
      "trigger_words": ["grundlegend", "fundamental", "basis", "wesentlich"]
    },
    {
      "name": "steel_manning",
      "description": "Konstruiere die stärkste Version eines Arguments, bevor du es analysierst",
      "trigger_words": ["argument", "widerspruch", "gegenargument", "kritik"]
    }
  ],
  "execution": {
    "max_depth": 5,
    "timeout_ms": 30000,
    "halt_on_contradiction": true,
    "backtracking_enabled": true,
    "think_aloud": true
  },
  "project_specific": {
    "domains": ["webdev", "blockchain", "ecommerce"],
    "context_weight": {
      "technical": 0.7,
      "business": 0.3
    },
    "focus_areas": [
      "architektur",
      "integration",
      "performance",
      "skalierbarkeit"
    ]
  }
}